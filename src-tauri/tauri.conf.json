{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Stream Overlay",
  "version": "0.2.6",
  "identifier": "art.h0kd.streamoverlay",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "control",
        "title": "Stream Overlay",
        "url": "control.html",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "app", "dmg"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "resources": [],
    "copyright": "",
    "category": "Utility",
    "shortDescription": "Twitch Channel Points video overlay",
    "longDescription": "Dispara videos en un overlay de OBS cuando tus viewers canjean Channel Points en Twitch. Self-hosted, sin servicios externos."
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/h0kd/h0kd-overlay/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDEwQkU5MjQ1NDY0Rjk2M0QKUldROWxrOUdSWksrRUY4WWtqamVqU0MvenIrNzJKVXpmUVdrZUZSRG1zeng0dkoxTGRtR3VMMEwK"
    }
  }
}
