{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Stream Overlay",
  "version": "0.2.0",
  "identifier": "art.h0kd.streamoverlay",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "control",
        "title": "Stream Overlay",
        "url": "control.html",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "resources": [],
    "copyright": "",
    "category": "Utility",
    "shortDescription": "Twitch Channel Points video overlay",
    "longDescription": "Self-hosted reemplazo de TriggerFyre. Dispara videos en overlay de OBS al canjear Channel Points."
  }
}
